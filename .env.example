# =============================================================================
# Supabase (obrigatório)
# =============================================================================

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública/anon do Supabase (usada no frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL base da aplicação (local ou produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Integração LLM (configurada no Supabase Edge Functions, não no frontend)
# =============================================================================
# Estas variáveis NÃO vão no .env.local — são secrets da Edge Function.
# Configurar via:
#   supabase secrets set LLM_API_KEY=sk-... --project-ref <ref>
#   supabase secrets set LLM_MODEL=gpt-4o-mini --project-ref <ref>
#   supabase secrets set LLM_BASE_URL=https://api.openai.com/v1 --project-ref <ref>
#
# Endpoints OpenAI-compatible suportados: OpenAI, Groq, Together, Anthropic
# (via proxy), Ollama local, OpenRouter, etc. Basta apontar LLM_BASE_URL.
#
# Quando LLM_API_KEY não está setada (ou falha), as Edge Functions retornam
# um fallback de templates locais — a UI exibe um badge "Modo offline (template)"
# para deixar claro ao usuário.
#
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Modo Demo (opcional — para desenvolvimento sem cloud)
# =============================================================================
# Quando true, a app roda 100% local com dados in-memory (lib/demo/data.ts).
# Geração de mensagens em demo SEMPRE retorna template hardcoded — não chama LLM.
# USE_DEMO_MODE=false

# =============================================================================
# E2E (opcional — para CI rodar tests/e2e/)
# =============================================================================
# E2E_EMAIL=
# E2E_PASSWORD=
